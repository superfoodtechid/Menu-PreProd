# GoScrapper Environment Configuration Template
# Copy this file to .env and fill in your values

# =====================================================
# Session Tokens (Multiple accounts supported)
# Format: BEARER_TOKEN_{PHONE_NUMBER}_{UNIQUE_ID}={TOKEN}
# =====================================================

BEARER_TOKEN_85136517321_salero_minang=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
BEARER_TOKEN_85136517318_ayam_geprek=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
BEARER_TOKEN_85182003794_warung_bakaran=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =====================================================
# Outlet Information
# Format: NAMA_OUTLET_{PHONE_NUMBER}_{UNIQUE_ID}={OUTLET_NAME}
# Format: CABANG_{PHONE_NUMBER}_{UNIQUE_ID}={BRANCH_NAME}
# =====================================================

NAMA_OUTLET_85136517321_salero_minang=Salero Minang Raya
CABANG_85136517321_salero_minang=Tanpa Cabang

NAMA_OUTLET_85136517318_ayam_geprek=Ayam Geprek Suroboyo Ampel
CABANG_85136517318_ayam_geprek=Tanpa Cabang

NAMA_OUTLET_85182003794_warung_bakaran=Warung Bakaran Amanah
CABANG_85182003794_warung_bakaran=Tanpa Cabang

# =====================================================
# Google Sheet Configuration (Optional)
# Uncomment to use custom sheet URL
# =====================================================

# SHEET_PUBLISHED_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/pubhtml?gid=0&single=true

# =====================================================
# Proxy Configuration (Optional, e.g., Cloudflare WARP SOCKS5)
# =====================================================
# USE_PROXY=false
# PROXY_SERVER=socks5://127.0.0.1:40000

# =====================================================
# Notes:
# - BEARER_TOKEN: Obtain from GoFood portal after login (OTP authentication)
# - Phone numbers: Use format without leading +
# - UNIQUE_ID: Any unique identifier to differentiate same phone with different outlets
# - Outlet names: Will be overridden by Google Sheet mapping if available
# - Multiple accounts: Add more BEARER_TOKEN_* entries as needed
# =====================================================
